{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "functions": {
    "supabase/functions/chat/index.ts": {
      "runtime": "nodejs18.x"
    },
    "supabase/functions/momo-pay/index.ts": {
      "runtime": "nodejs18.x"
    },
    "supabase/functions/momo-status/index.ts": {
      "runtime": "nodejs18.x"
    }
  },
  "env": {
    "SUPABASE_URL": "@supabase-url",
    "SUPABASE_ANON_KEY": "@supabase-anon-key",
    "SYCOMINDUSTRY_LTD_API_KEY": "@sycomindustry-ltd-api-key"
  },
  "build": {
    "env": {
      "SUPABASE_URL": "@supabase-url",
      "SUPABASE_ANON_KEY": "@supabase-anon-key",
      "SYCOMINDUSTRY_LTD_API_KEY": "@sycomindustry-ltd-api-key"
    }
  }
}
